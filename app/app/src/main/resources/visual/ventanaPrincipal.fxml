                        <Button mnemonicParsing="false" onAction="#abrirCreacionParado" prefHeight="60.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Agregar parada" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0" />

                        <Button mnemonicParsing="false" onAction="#abrirCreacionRuta" prefHeight="60.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Agregar ruta" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="100.0" />
                  <Pane layoutX="23.0" layoutY="217.0" prefHeight="269.0" prefWidth="200.0" style="-fx-background-color: #F0F0F0;">
