                        <Button layoutX="7.0" layoutY="201.0" mnemonicParsing="false" prefHeight="46.0" prefWidth="187.0" text="Calcular" onAction="#buscarMostrarRutaOptima" />
                     </children>
                  </Pane>
                    </children>
                </AnchorPane>

                <AnchorPane fx:id="panelDerecho" minHeight="0.0" minWidth="0.0" />
            </items>
        </SplitPane>
