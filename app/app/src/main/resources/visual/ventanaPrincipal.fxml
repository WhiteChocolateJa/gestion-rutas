<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.pucmm.rutas.gestionrutas.ui.HelloController">
    <children>
        <SplitPane dividerPositions="0.25" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane fx:id="panelIzquierdo" maxWidth="500.0" minHeight="0.0" minWidth="0.0" prefWidth="400.0">
                    <children>

                        <Button layoutX="20.0" layoutY="14.0" mnemonicParsing="false" onAction="#abrirCreacionParado" prefHeight="32.0" prefWidth="142.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Agregar parada" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="14.0">
                            <font>
                                <Font size="5.0" />
                            </font>
                        </Button>

                        <Button layoutX="20.0" layoutY="61.0" mnemonicParsing="false" onAction="#abrirCreacionRuta" prefHeight="32.0" prefWidth="142.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Agregar ruta" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="61.0" />

                        <Button layoutX="20.0" layoutY="108.0" mnemonicParsing="false" onAction="#abrirEditarParadas" prefHeight="26.0" prefWidth="120.0" style="-fx-font-size: 12px;" text="Editar paradas" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="108.0" />

                        <Button layoutX="20.0" layoutY="143.0" mnemonicParsing="false" onAction="#abrirEditarRutas" prefHeight="26.0" prefWidth="120.0" style="-fx-font-size: 12px;" text="Editar rutas" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="143.0" />

                        <Pane layoutX="23.0" layoutY="217.0" prefHeight="269.0" prefWidth="200.0" style="-fx-background-color: #F0F0F0;">
                            <children>
                                <Label layoutX="66.0" layoutY="14.0" text="Calcular ruta" />
                                <Label layoutX="38.0" layoutY="54.0" text="Origen" />
                                <Label layoutX="132.0" layoutY="54.0" text="Destino" />
                                <ComboBox fx:id="cbxOrigen2" layoutX="8.0" layoutY="84.0" prefHeight="25.0" prefWidth="84.0" />
                                <ComboBox fx:id="cbxDestino2" layoutX="110.0" layoutY="84.0" prefHeight="25.0" prefWidth="84.0" />
                                <ComboBox fx:id="cbxCriterio" layoutX="32.0" layoutY="159.0" prefHeight="25.0" prefWidth="134.0" />
                                <Label layoutX="81.0" layoutY="135.0" text="Criterio" />
                                <Button layoutX="7.0" layoutY="201.0" mnemonicParsing="false" onAction="#buscarMostrarRutaOptima" prefHeight="46.0" prefWidth="187.0" text="Calcular" />
                            </children>
                        </Pane>

                    </children>
                </AnchorPane>

                <AnchorPane fx:id="panelDerecho" minHeight="0.0" minWidth="0.0" />
            </items>
        </SplitPane>
    </children>
</AnchorPane>