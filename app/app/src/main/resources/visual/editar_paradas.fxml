<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="420.0" prefWidth="460.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.pucmm.rutas.gestionrutas.control.controlEditarParadas">
    <children>

        <Label layoutX="20.0" layoutY="20.0" styleClass="label-titulo" text="Administrar Paradas" />

        <Label layoutX="20.0" layoutY="65.0" text="Parada" />

        <ComboBox fx:id="cbxParadas" layoutX="20.0" layoutY="90.0" onAction="#cargarDatosParada" prefWidth="300.0" promptText="Seleccione una parada" />

        <Label layoutX="20.0" layoutY="135.0" text="Código" />
        <TextField fx:id="txtCodigo" disable="true" editable="false" layoutX="100.0" layoutY="130.0" prefWidth="320.0" promptText="Código" />

        <Label layoutX="20.0" layoutY="175.0" text="Nombre" />
        <TextField fx:id="txtNombre" layoutX="100.0" layoutY="170.0" prefWidth="320.0" promptText="Nombre" />

        <Label layoutX="20.0" layoutY="215.0" text="Descripción" />
        <TextArea fx:id="txtDescripcion" layoutX="100.0" layoutY="210.0" prefHeight="80.0" prefWidth="320.0" promptText="Descripción" wrapText="true" />

        <Label layoutX="20.0" layoutY="310.0" text="Zona" />
        <TextField fx:id="txtZona" layoutX="100.0" layoutY="305.0" prefWidth="320.0" promptText="Zona" />

        <Button layoutX="120.0" layoutY="360.0" onAction="#cerrarVentana" prefWidth="90.0" text="Cerrar" />

        <Button layoutX="220.0" layoutY="360.0" onAction="#eliminarParada" prefWidth="100.0" styleClass="button-danger" text="Eliminar" />

        <Button layoutX="330.0" layoutY="360.0" onAction="#modificarParada" prefWidth="100.0" styleClass="button-primary" text="Modificar" />

    </children>
</AnchorPane>
