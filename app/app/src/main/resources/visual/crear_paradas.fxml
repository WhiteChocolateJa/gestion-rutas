<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TitledPane animated="false"
            prefHeight="348.0"
            prefWidth="460.0"
            stylesheets="@styles.css"
            text="Creación de paradas"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.pucmm.rutas.gestionrutas.control.controlParadas">

    <content>
        <AnchorPane prefHeight="303.0" prefWidth="458.0">
            <children>

                <GridPane hgap="10.0" vgap="10.0"
                          AnchorPane.leftAnchor="20.0"
                          AnchorPane.rightAnchor="20.0"
                          AnchorPane.topAnchor="20.0">

                    <columnConstraints>
                        <ColumnConstraints minWidth="90.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <Label text="Código" GridPane.rowIndex="0" />
                    <TextField fx:id="txtCodigo" disable="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Nombre" GridPane.rowIndex="1" />
                    <TextField fx:id="txtNombre"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Descripción" GridPane.rowIndex="2" />
                    <TextArea fx:id="txtDescripcion"
                              prefHeight="70.0"
                              wrapText="true"
                              GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Zona" GridPane.rowIndex="3" />
                    <TextField fx:id="txtZona"
                               GridPane.columnIndex="1" GridPane.rowIndex="3" />

                </GridPane>

                <!-- BOTONES -->
                <Button layoutX="220.0"
                        layoutY="260.0"
                        onAction="#cerrarVentana"
                        prefWidth="100.0"
                        text="Cancelar" />

                <Button layoutX="330.0"
                        layoutY="260.0"
                        onAction="#continuarACrearRuta"
                        prefWidth="100.0"
                        styleClass="button-primary"
                        text="Aceptar" />

            </children>
        </AnchorPane>
    </content>
</TitledPane>